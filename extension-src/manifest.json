{
  "manifest_version": 3,
  "name": "API Tester",
  "version": "0.1.0",
  "description": "REST API testing tool",
  "action": {
    "default_title": "API Tester を開く"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
